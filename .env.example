# ============ LLM（MiniMax，OpenAI 兼容）============
MINIMAX_API_KEY=your_key_here
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
# 可选: MiniMax-M3 / MiniMax-M2.5 / MiniMax-M2
MINIMAX_MODEL=MiniMax-M2
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048

# ============ 第二供应商：DashScope / Qwen（评测异构裁判用，可选）============
# 配了此 key 后，评测裁判可切到 Qwen（EVAL_JUDGE_PROVIDER=dashscope）或开陪审团（EVAL_JURY=true）
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ============ 向量库 / RAG ============
# chroma | keyword(无依赖降级)
VECTOR_BACKEND=chroma
CHROMA_PERSIST_DIR=./data/chroma
KB_DIR=./data/kb
RAG_TOP_K=4
# embedding: chroma_default(内置MiniLM) | sentence_transformers
EMBEDDING_BACKEND=chroma_default
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# ============ 长期记忆 ============
# mem0 | json(无依赖降级)
MEMORY_BACKEND=mem0
MEMORY_JSON_PATH=./data/memory_store.json
# mem0 内部记忆抽取/CRUD 用的 LLM（需支持 json_object；think 由代码剥离）
MEM0_LLM_MODEL=MiniMax-M2
MEM0_VECTOR_PATH=./data/mem0_chroma
MEM0_COLLECTION=mem0_memories

# ============ 短期记忆 / Checkpointer ============
# memory(进程内) | sqlite
CHECKPOINTER=memory
CHECKPOINT_DB=./data/checkpoints.sqlite

# ============ 业务参数 schema（ETIM/ECLASS 驱动）============
PARAM_SCHEMA_PATH=./data/param_schema.json

# ============ HITL 人工中断阈值 ============
# 触发人工审批的报价金额阈值（占位，报价Agent接入后启用）
HITL_HIGH_VALUE_AMOUNT=50000

# ============ 仿真评测（app.eval）============
EVAL_MAX_TURNS=12
EVAL_SIM_TEMPERATURE=0.8
EVAL_LLM_JUDGE=false
EVAL_MAX_REPLY_CHARS=600
# 裁判主成员供应商/模型：留空=minimax。设 dashscope 可让裁判≠生成模型，消自我偏好
EVAL_JUDGE_PROVIDER=
EVAL_JUDGE_MODEL=
# 陪审团：true 且 DASHSCOPE_API_KEY 就绪时，MiniMax+Qwen 各判一次再投票/取均值
EVAL_JURY=false
EVAL_DASHSCOPE_JUDGE_MODEL=qwen-plus

# ============ 杂项 ============
LOG_LEVEL=INFO
