# ============ LLM（MiniMax，OpenAI 兼容）============
MINIMAX_API_KEY=your_key_here
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
# 可选: MiniMax-M3 / MiniMax-M2.5 / MiniMax-M2
MINIMAX_MODEL=MiniMax-M2
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048

# ============ 向量库 / RAG ============
# chroma | keyword(无依赖降级)
VECTOR_BACKEND=chroma
CHROMA_PERSIST_DIR=./data/chroma
KB_DIR=./data/kb
RAG_TOP_K=4
# embedding: chroma_default(内置MiniLM) | sentence_transformers
EMBEDDING_BACKEND=chroma_default
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# ============ 长期记忆 ============
# mem0 | json(无依赖降级)
MEMORY_BACKEND=json
MEMORY_JSON_PATH=./data/memory_store.json

# ============ 短期记忆 / Checkpointer ============
# memory(进程内) | sqlite
CHECKPOINTER=memory
CHECKPOINT_DB=./data/checkpoints.sqlite

# ============ 业务参数 schema（ETIM/ECLASS 驱动）============
PARAM_SCHEMA_PATH=./data/param_schema.json

# ============ HITL 人工中断阈值 ============
# 触发人工审批的报价金额阈值（占位，报价Agent接入后启用）
HITL_HIGH_VALUE_AMOUNT=50000

# ============ 杂项 ============
LOG_LEVEL=INFO
